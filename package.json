{
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n be,fe,ai -c cyan,yellow,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:ai\"",
    "dev:backend": "cd backend/CogniLight.Api && dotnet run --launch-profile http",
