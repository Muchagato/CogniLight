# CogniLight AI Service — LLM Configuration
# Copy this file to .env and fill in your values.

# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Your API key (required for LLM responses; without it, demo mode is used)
LLM_API_KEY=sk-ant-api03-your-key-here

# Optional overrides (defaults are set per provider)
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-haiku-4-5-20251001  (or gpt-4.1-nano for OpenAI)

# Telemetry ingestion
# INGEST_INTERVAL=10
# DATABASE_PATH=../backend/CogniLight.Api/cognilight.db
